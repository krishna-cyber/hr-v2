# Example environment variables for the server
# Copy this file to .env and fill in real values. Do NOT commit .env with secrets.

# Server Configuration
BASE_URL=http://localhost:4100
PORT=4100
CLIENT_URL=http://localhost:4200

# Database
# Use a full Mongo connection string or a hosted DB URI
DB_URL=

# JWT Authentication
JWT_SECRET_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4100/api/auth/google/callback

# Gmail Configuration
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_USER=your_email@example.com
GMAIL_PASS=

# Slack Integration
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_GENERAL_CHANNEL_ID=CXXXXXXXX
SLACK_CHANNEL_ID=CXXXXXXXX

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS=false

# GitHub Integration
GITHUB_ORG_NAME=
GITHUB_ACCESS_TOKEN=

# Misc
TECH_LEAD_EMAIL=techlead@example.com
SLACK_GITHUB_ACCESS_CHANNEL_ID=CXXXXXXXX
