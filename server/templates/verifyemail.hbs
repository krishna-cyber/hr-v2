<div
  style="font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background-color:#eaf2fb;padding:32px 12px;"
>
  <div
    style='max-width:600px;margin:auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(28,119,187,0.10);'
  >

    <!-- Logo -->
    <div
      style='background-color:#ffffff;padding:14px 28px;border-bottom:1px solid #d4e8f7;'
    >
      <img
        src='https://images.crunchbase.com/image/upload/c_pad,f_auto,q_auto:eco,dpr_1/vuhp9rc1llrkmfimwf7o'
        alt='Palmmind Logo'
        width='140'
        height='46'
        style='display:block;object-fit:contain;'
      />
    </div>

    <!-- Title -->
    <div style='background-color:#1c77bb;padding:22px 28px;'>
      <h1
        style='color:#ffffff;margin:0 0 4px;font-size:20px;font-weight:700;'
      >Welcome to Palm Mind HR</h1>
      <p
        style='color:rgba(255,255,255,0.65);margin:0;font-size:11px;letter-spacing:1.1px;text-transform:uppercase;font-weight:500;'
      >HR Management System</p>
    </div>

    <!-- Body -->
    <div style='padding:36px 32px;'>
      <p style='font-size:15px;color:#444;margin:0 0 6px;'>
        Dear
        <strong style='color:#1c77bb;'>{{firstName}}</strong>,
      </p>
      <p style='font-size:15px;color:#556;margin:0 0 24px;line-height:1.7;'>
        Welcome to
        <strong style='color:#1a2e45;'>Palm Mind Technology HR System</strong>.
        Your account has been created successfully. Please verify click the
        following button:
      </p>

      <!-- Credentials Card -->
      <div
        style='background:#f7fbff;border-radius:8px;border:1px solid #d4e8f7;border-left:4px solid #1c77bb;padding:4px 20px;margin-bottom:24px;'
      >
        <table style='width:100%;border-collapse:collapse;table-layout:fixed;'>
          <tr>
            <td
              style='padding:11px 0;border-bottom:1px solid #e2edf7;vertical-align:top;width:38%;'
            >
              <span
                style='font-size:11px;font-weight:700;color:#7a9bbf;text-transform:uppercase;letter-spacing:0.8px;'
              >Email</span>
            </td>
            <td
              style='padding:11px 0;border-bottom:1px solid #e2edf7;vertical-align:top;'
            >
              <span
                style='font-size:14px;color:#1a2e45;font-weight:500;word-break:break-word;display:block;'
              >{{email}}</span>
            </td>
          </tr>

        </table>
      </div>

      <!-- Warning -->

      <!-- CTA -->
      <div style='text-align:center;'>
        <a
          href='{{logiverificationlink}}'
          style='background-color:#1c77bb;color:#ffffff;padding:13px 36px;text-decoration:none;border-radius:6px;font-size:15px;font-weight:600;display:inline-block;letter-spacing:0.3px;'
        >
          Verify Email Address &rarr;
        </a>
      </div>
    </div>

    <!-- Footer -->
    <div
      style='background-color:#f0f6fc;border-top:1px solid #d4e8f7;padding:20px 32px;text-align:center;'
    >
      <p style='margin:0;font-size:13px;color:#555;'>Best regards, &nbsp;<strong
          style='color:#1c77bb;'
        >HR Department</strong></p>
      <p style='margin:8px 0 0;font-size:11px;color:#aab8c8;'>This is an
        automated message &mdash; please do not reply directly to this email.</p>
    </div>

  </div>
</div>