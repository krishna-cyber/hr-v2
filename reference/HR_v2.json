          "200": {
            "description": "Successful response"
          }
        },
        "description": "Sign in with email",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "x-apidog-orders": [
                  "email",
                  "password"
                ],
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        }
      }
    },
    "/test": {
      "get": {
        "summary": "Test Endpoint",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        },
        "description": "This is a test endpoint.",
        "operationId": "/test",
        "tags": [
          "/test"
        ]
      }
